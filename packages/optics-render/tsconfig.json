{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": ["es2023", "dom"],
    "module": "nodenext",
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "noUnusedLocals": true,
    "strict": true,
    "target": "es2023",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src", "tests"]
}
